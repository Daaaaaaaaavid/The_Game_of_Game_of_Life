<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp"
    android:background="#111827">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@android:drawable/ic_media_previous"
        android:background="@android:color/transparent"
        android:layout_gravity="start"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GAME OF LIFE"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginTop="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Multiplayer"
        android:textSize="20sp"
        android:textColor="#BBBBBB"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnHostGame"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:text="SPIEL HOSTEN"
        android:layout_marginBottom="32dp"/>

    <View
        android:layout_width="280dp"
        android:layout_height="1dp"
        android:background="#374151"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RAUM-ID DES PARTNERS:"
        android:textColor="#9CA3AF"
        android:textSize="12sp"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etRoomId"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:hint="z.B. 54321"
        android:textColorHint="#4B5563"
        android:textColor="#FFFFFF"
        android:backgroundTint="#3B82F6"
        android:inputType="number"
        android:textAlignment="center"
        android:padding="12dp"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnJoinGame"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:text="SPIEL BEITRETEN"
        android:layout_marginBottom="16dp"/>

</LinearLayout>
